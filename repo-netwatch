#!/usr/bin/env bash
# repo-netwatch — reacts to network changes (run by launchd via WatchPaths on
# /Library/Preferences/SystemConfiguration). When the Mac comes back online it
# re-checks GitHub auth, force-refreshes the SwiftBar plugin (no waiting for the
# 5-min cycle, no manual click), and posts a macOS notification. Offline→online
# only — transitions in the other direction just update the menu bar quietly.
export PATH="/opt/homebrew/bin:$HOME/.local/bin:/usr/bin:/bin:/usr/sbin:/sbin"

# Same token trick as the plugin: a GUI-spawned background process can't answer
# the keychain prompt, so feed gh the token from a file. GH_TOKEN bypasses the
# keyring entirely.
TOKEN_FILE="$HOME/.config/gh/swiftbar-token"
[ -r "$TOKEN_FILE" ] && export GH_TOKEN="$(cat "$TOKEN_FILE")"

PLUGIN_NAME="github"                       # matches swiftbar-plugins/github.5m.sh
STATE_FILE="$HOME/.cache/repos/netwatch.state"
mkdir -p "$(dirname "$STATE_FILE")"

# Notify via the bundled app so the alert shows the GitHub mark instead of the
# Script Editor icon; fall back to raw osascript if the app isn't built.
NOTIFIER="$(cd "$(dirname "$0")" && pwd)/notifier/GitHub Repos.app"
notify() { # subtitle, message
  if [ -d "$NOTIFIER" ]; then
    open -gjn "$NOTIFIER" --args "GitHub Repos" "$1" "$2" >/dev/null 2>&1
  else
    osascript -e "display notification \"$2\" with title \"GitHub Repos\" subtitle \"$1\"" >/dev/null 2>&1
  fi
}

# A single wifi/network change fires WatchPaths several times in a burst — let
# the interface settle so the connectivity check reflects the final state.
sleep 2

# Online == GitHub is reachable AND the token validates. This is the exact
# condition the plugin uses to decide "logged in", so the menu bar and the
# notification can never disagree. curl bounds the wait when truly offline.
online=0
if curl -sf --max-time 4 https://api.github.com/zen >/dev/null 2>&1 \
   && gh auth status >/dev/null 2>&1; then
  online=1
fi
[ "$online" -eq 1 ] && now=online || now=offline

prev="$(cat "$STATE_FILE" 2>/dev/null || echo unknown)"
echo "$now" > "$STATE_FILE"

# Nothing changed since the last fire — don't spam refreshes or notifications.
[ "$now" = "$prev" ] && exit 0

# Update the menu bar immediately on any real transition.
open -g "swiftbar://refreshplugin?name=$PLUGIN_NAME" >/dev/null 2>&1 || true

# Only announce the reconnect.
if [ "$now" = "online" ]; then
  notify "Back online" "Signed in to GitHub ✓"
fi
