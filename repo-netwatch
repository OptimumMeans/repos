#!/usr/bin/env bash
# repo-netwatch — reacts to network changes (run by launchd via WatchPaths on
# /Library/Preferences/SystemConfiguration). When the Mac comes back online it
# re-checks GitHub auth and posts a "Back online" notification. The Repos app
# self-refreshes on reconnect, so there's nothing here to poke. Offline→online
# only — the other direction is silent.
export PATH="/opt/homebrew/bin:$HOME/.local/bin:/usr/bin:/bin:/usr/sbin:/sbin"

# A GUI-spawned background process can't answer the keychain prompt, so feed gh
# the token from a file. GH_TOKEN bypasses the keyring entirely.
TOKEN_FILE="$HOME/.config/gh/swiftbar-token"
[ -r "$TOKEN_FILE" ] && export GH_TOKEN="$(cat "$TOKEN_FILE")"

STATE_FILE="$HOME/.cache/repos/netwatch.state"
mkdir -p "$(dirname "$STATE_FILE")"

# All notifications go through repo-notify (GitHub-icon app, osascript fallback).
notify() { "$(cd "$(dirname "$0")" && pwd)/repo-notify" "$1" "$2"; }  # subtitle, message

# A single wifi/network change fires WatchPaths several times in a burst — let
# the interface settle so the connectivity check reflects the final state.
sleep 2

# Online == GitHub is reachable AND the token validates. curl bounds the wait
# when truly offline.
online=0
if curl -sf --max-time 4 https://api.github.com/zen >/dev/null 2>&1 \
   && gh auth status >/dev/null 2>&1; then
  online=1
fi
[ "$online" -eq 1 ] && now=online || now=offline

prev="$(cat "$STATE_FILE" 2>/dev/null || echo unknown)"
echo "$now" > "$STATE_FILE"

# Nothing changed since the last fire — don't spam notifications.
[ "$now" = "$prev" ] && exit 0

# Only announce the reconnect.
if [ "$now" = "online" ]; then
  notify "Back online" "Signed in to GitHub ✓"
fi
