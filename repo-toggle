#!/usr/bin/env bash
# repo-toggle — click handler for the SwiftBar GitHub plugin.
# Toggles a repo on/off via the `repo` tool and shows a macOS notification.
# Usage: repo-toggle <on|off> <repo-name>
export PATH="/opt/homebrew/bin:$HOME/.local/bin:/usr/bin:/bin:/usr/sbin:/sbin"

# Load token from file so clones work when SwiftBar runs us without a keychain
# session. gh repo clone and the gh git-credential helper both honor GH_TOKEN.
TOKEN_FILE="$HOME/.config/gh/swiftbar-token"
[ -r "$TOKEN_FILE" ] && export GH_TOKEN="$(cat "$TOKEN_FILE")"

action="${1:-}"; name="${2:-}"
# All notifications go through repo-notify (GitHub-icon app, osascript fallback).
notify() { "$(cd "$(dirname "$0")" && pwd)/repo-notify" "$1" "$2"; }  # subtitle, message

case "$action" in
  on)
    if out=$(repo on "$name" 2>&1); then
      notify "$name" "Added to this machine ✓"
    else
      notify "$name" "Couldn't add — $(printf '%s' "$out" | tail -1)"
    fi ;;
  off)
    if out=$(repo off "$name" 2>&1); then
      notify "$name" "Offloaded to cloud ✓"
    else
      notify "$name" "Kept on machine — unsaved/unpushed work"
    fi ;;
  *)
    notify "error" "unknown action: $action" ;;
esac
